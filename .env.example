# =============================================================================
# 85 TATTOO — variáveis de ambiente
# =============================================================================
# Este arquivo lista TODAS as variáveis realmente lidas pelo código do projeto.
# Copie para `.env` e preencha os valores reais em ambiente local.
# NUNCA cometa `.env` no repositório (já protegido em .gitignore).
# Nunca coloque valores reais aqui.

# -----------------------------------------------------------------------------
# 1. Frontend (Vite) — PÚBLICO, embutido no bundle do navegador
# -----------------------------------------------------------------------------
# São os únicos valores que podem receber o prefixo VITE_. Vazam para o
# cliente por design — só use publishable/anon keys aqui.

# URL do backend Supabase (Lovable Cloud). Obrigatória.
VITE_SUPABASE_URL=

# Publishable key (sb_publishable_...) do Supabase. Obrigatória. Pública.
# Compatibilidade: o frontend também aceita VITE_SUPABASE_ANON_KEY se esse for
# o nome já configurado no deploy.
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# ID do projeto Supabase. Opcional — usada apenas em scripts locais.
VITE_SUPABASE_PROJECT_ID=

# SHA do commit atual, exibido em /admin/configuracoes/sistema. Opcional.
VITE_COMMIT_SHA=

# -----------------------------------------------------------------------------
# 2. Edge Functions (Supabase / Lovable Cloud) — PRIVADO, NUNCA no frontend
# -----------------------------------------------------------------------------
# Estas variáveis são lidas apenas dentro de `supabase/functions/*`. NÃO devem
# aparecer no bundle do frontend em hipótese alguma. Configure-as pela UI de
# secrets do Lovable Cloud (Cloud → Secrets), nunca no repositório.

# Injetadas automaticamente pelo runtime Supabase — não precisa configurar:
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY

# Turnstile (Cloudflare) — validação server-side de captcha. Opcional.
# Usada em supabase/functions/verify-turnstile.
TURNSTILE_SECRET_KEY=

# Site key do Turnstile — pública, embutida no HTML. Opcional.
# Não é lida pelo Vite hoje; se quiser expor via env, use VITE_TURNSTILE_SITE_KEY.
# VITE_TURNSTILE_SITE_KEY=

# Google Sheets — usada em supabase/functions/backup-to-sheets. Opcional.
# Só é obrigatória se o backup para planilha estiver ativo.
GOOGLE_SHEETS_API_KEY=

# Lovable AI Gateway — gerenciada pelo Lovable, já provisionada. Não editar.
# LOVABLE_API_KEY=
