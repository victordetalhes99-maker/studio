# Headers para Cloudflare Pages
# Documentação: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

# Assets versionados por hash (Vite) — cache imutável por 1 ano
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# index.html nunca deve ser servido do cache
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
